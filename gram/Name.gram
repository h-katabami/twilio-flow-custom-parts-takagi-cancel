#JSGF V1.0 SJIS ja;

grammar generated_japanese_name;

public <japanese_name> = <pre> ((<myouji> _<namae>)|<7-9hiragana>) <post>;

<pre>=[えー|えっと|えーと|えと] <GARBAGE>*;

<post>=[です|ともうします] <GARBAGE>*;

<7-9hiragana> = <hiragana>_<hiragana>_<hiragana>_<hiragana>_<hiragana>_<hiragana>_<hiragana>[_<hiragana>][_<hiragana>];

